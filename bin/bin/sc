#!/bin/sh
#
# scrot -> 0x0.st

file=/tmp/"$(date +%s)".png

case "$1" in
    "") maim -su "$file" || exit 1;;
    f) maim -u "$file";;
esac

yn=$(printf "yes\nno" | dmenu -l 3 -p "upload scrot to 0x0.st?")

case "$yn" in
    yes) curl -F file=@"$file" "https://0x0.st" | xclip -sel clip &&
        herbe "uploaded to 0x0.";;

    no) herbe "upload cancelled.";;
esac
