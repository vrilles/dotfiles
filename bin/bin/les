#!/bin/sh
#
# browse/open docs

ext() {
    basename "$1" | sed 's/.*\.//'
}

list="$(
    find "$HOME/docs" |
        grep '.pdf\|.epub\|.djvu' |
        sed 's/\/home\/lpy\/docs\///' |
        sed 's/\//\ >\ /g' |
        sort |
        dmenu -l 10 |
        sed 's/\ >\ /\//g'
)"

out="/home/lpy/docs/$list"

[ -f "$out" ] &&
    if [ "$(ext "$out")" = "epub" ]
        then
            ebook-viewer "$out"
        else
            zathura "$out"
    fi
